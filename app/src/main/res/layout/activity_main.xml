<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="32dp"
        android:fitsSystemWindows="true">

        <!-- 顶栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="14dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_translate"
                app:tint="@color/primary"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/title_app"
                android:maxLines="1"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- 网络状态 -->
            <LinearLayout
                android:id="@+id/networkIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_network_badge"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <View
                    android:id="@+id/networkDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_circle_small" />

                <TextView
                    android:id="@+id/tvNetworkStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/network_online"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckUpdate"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:text="🔄"
                android:textSize="18sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistory"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="📜"
                android:textSize="18sp"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFavorites"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="⭐"
                android:textSize="18sp"
                app:cornerRadius="16dp" />

        </LinearLayout>

        <!-- 模式切换 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOfflineMode"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="@string/mode_offline"
                        android:textSize="13sp"
                        app:backgroundTint="@color/offline_active"
                        app:cornerRadius="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOnlineMode"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:text="@string/mode_online"
                        android:textSize="13sp"
                        app:backgroundTint="@color/offline_inactive"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <!-- 翻译源切换（在线模式显示） -->
                <HorizontalScrollView
                    android:id="@+id/layoutSourceSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/source_label"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSrcMyMemory"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="6dp"
                            android:text="@string/source_mymemory"
                            android:textColor="@color/text_on_primary"
                            android:textSize="10sp"
                            app:backgroundTint="@color/mymemory_orange"
                            app:cornerRadius="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSrcGoogle"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="6dp"
                            android:text="@string/source_google"
                            android:textSize="11sp"
                            app:cornerRadius="16dp"
                            app:strokeColor="@color/google_blue"
                            app:strokeWidth="1.5dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSrcBing"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="6dp"
                            android:text="@string/source_bing"
                            android:textSize="11sp"
                            app:cornerRadius="16dp"
                            app:strokeColor="@color/bing_green"
                            app:strokeWidth="1.5dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSrcLibre"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginStart="6dp"
                            android:text="@string/source_libre"
                            android:textSize="11sp"
                            app:cornerRadius="16dp"
                            app:strokeColor="@color/libre_purple"
                            app:strokeWidth="1.5dp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 快捷入口 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOcr"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/btn_ocr"
                android:textSize="13sp"
                app:cornerRadius="22dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDictionary"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/btn_dictionary"
                android:textSize="13sp"
                app:cornerRadius="22dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp" />
        </LinearLayout>

        <!-- 语言方向 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvSourceLang"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/source_lang_lao"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSwitch"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="⇄"
                    android:textSize="20sp"
                    app:backgroundTint="@color/primary_light"
                    app:cornerRadius="23dp" />

                <TextView
                    android:id="@+id/tvTargetLang"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/target_lang_zh"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 输入区域 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <EditText
                    android:id="@+id/etSource"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/input_hint"
                    android:inputType="textMultiLine"
                    android:minHeight="72dp"
                    android:textColor="@color/text_body"
                    android:textColorHint="@color/text_hint"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnVoice"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/primary"
                        android:contentDescription="@string/listening"
                        android:padding="12dp"
                        android:src="@drawable/ic_mic"
                        app:tint="@android:color/white" />

                    <TextView
                        android:id="@+id/tvListeningHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/listening"
                        android:textColor="@color/accent_red"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/btnClear"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="清空"
                        android:padding="8dp"
                        android:src="@drawable/ic_clear"
                        app:tint="@color/text_hint" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTranslate"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginStart="8dp"
                        android:paddingHorizontal="20dp"
                        android:text="@string/btn_translate"
                        android:textColor="@color/text_on_primary"
                        android:textSize="14sp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="21dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 首次打开空状态引导 -->
        <TextView
            android:id="@+id/tvEmptyStateHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/empty_state_hint"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />

        <!-- 翻译结果 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:textColor="@color/text_body"
                    android:textSize="17sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnCopy"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/copied"
                        android:padding="8dp"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/text_hint" />

                    <ImageButton
                        android:id="@+id/btnSpeakResult"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/tts_speaking"
                        android:padding="8dp"
                        android:src="@drawable/ic_speaker"
                        app:tint="@color/primary" />

                    <ImageButton
                        android:id="@+id/btnFavoriteResult"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/favorited"
                        android:padding="8dp"
                        android:src="@drawable/ic_star"
                        app:tint="@color/text_hint" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 分类词库 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_title"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupCategories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true" />
                </HorizontalScrollView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCategoryEntries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/footer_text"
            android:textColor="@color/text_hint"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>