<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FAFAFA"
    tools:context=".ui.MainActivity">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 当前识别的语言标签 -->
        <TextView
            android:id="@+id/tvDetectedLang"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="自动识别：等待输入..."
            android:textSize="14sp"
            android:textColor="#666666"/>

        <!-- TTS 开关 -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchTts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊"
            android:checked="true"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- 原文区域 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSource"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnRecord"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        app:layout_constraintHeight_percent="0.35">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSourceLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="原文"
                    android:textSize="12sp"
                    android:textColor="#999999"/>

                <ImageButton
                    android:id="@+id/btnSpeakSource"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="朗读原文"/>
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvSourceText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="#333333"
                    android:hint="说话后自动识别语言..."
                    android:textColorHint="#CCCCCC"/>
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 文字翻译测试 -->
    <LinearLayout
        android:id="@+id/textTranslateBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/cardSource"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etTextInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="输入文字测试翻译..."
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/rounded_edittext"
            android:inputType="text"
            android:maxLines="1"/>

        <Button
            android:id="@+id/btnTextTranslate"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="翻译"
            android:textSize="13sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- 录音按钮 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_btn_speak_now"
        android:contentDescription="录音"
        app:layout_constraintTop_toBottomOf="@id/textTranslateBar"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"
        app:backgroundTint="#F44336"/>

    <!-- 状态提示 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="点击麦克风开始"
        android:textSize="12sp"
        android:textColor="#999999"
        app:layout_constraintBottom_toTopOf="@id/cardTarget"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

    <!-- 译文区域 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTarget"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#E3F2FD"
        app:layout_constraintTop_toBottomOf="@id/btnRecord"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        app:layout_constraintHeight_percent="0.35">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTargetLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="译文"
                    android:textSize="12sp"
                    android:textColor="#666666"/>

                <ImageButton
                    android:id="@+id/btnSpeakTarget"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="朗读译文"/>
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvTargetText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="#1565C0"
                    android:hint="翻译结果将显示在这里..."
                    android:textColorHint="#90CAF9"/>
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
