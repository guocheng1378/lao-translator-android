<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LaoTranslator" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="chipStyle">@style/LaoChip</item>
    </style>

    <style name="LaoChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="chipStrokeColor">@color/primary_light</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/chip_text</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="android:textSize">13sp</item>
        <item name="checkedIconVisible">false</item>
    </style>
</resources>
